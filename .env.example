# Copy this file to `.env` and replace the placeholder values for local use.

DATABASE_URL=file:${PWD}/prisma/dev.db
NITRO_JWT_SECRET=change-me-in-local-env
NITRO_DEV_AUTH_BYPASS=false
NITRO_DOCS_ENABLED=false
NUXT_PUBLIC_API_BASE=http://127.0.0.1:5678/api/v1
# NITRO_API_TOKEN=change-me-if-used

# Optional overrides for `npm run db:seed:dev`
# DEV_BOOTSTRAP_ADMIN_EMAIL=dev-admin@example.com
# DEV_BOOTSTRAP_ADMIN_PASSWORD=dev-admin-password
# DEV_BOOTSTRAP_MEMBER_EMAIL=dev-member@example.com
# DEV_BOOTSTRAP_MEMBER_PASSWORD=dev-member-password
